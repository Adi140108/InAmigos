---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  
  <main class="donate-page">
    <!-- Hero Header -->
    <section class="page-hero">
      <div class="container text-center">
        <div class="eyebrow center">
          <span class="eyebrow-dot"></span>
          <span>TRANSFORM COMPASSION INTO ACTION</span>
        </div>
        <h1 class="page-title">Direct Support Portal</h1>
        <p class="page-subtitle">
          Secure, transparent donations powered by Razorpay. 100% of public funds are directly allocated to field project costs, eligible for 50% tax deductions under Section 80G.
        </p>
      </div>
    </section>

    <!-- Checkout section -->
    <section class="checkout-section">
      <div class="container">
        <div class="checkout-wrapper">
          <form id="donationForm" class="checkout-form">
            
            <!-- Left Side: Inputs -->
            <div class="checkout-inputs">
              <!-- Step 1: Amount -->
              <div class="step-container">
                <h3 class="step-title"><span class="step-badge">1</span> Select Contribution Amount</h3>
                <div class="amount-presets">
                  <button type="button" class="preset-btn" data-value="500">₹500</button>
                  <button type="button" class="preset-btn active" data-value="1000">₹1,000</button>
                  <button type="button" class="preset-btn" data-value="2500">₹2,500</button>
                  <button type="button" class="preset-btn" data-value="5000">₹5,000</button>
                </div>
                <div class="custom-amount-group">
                  <label for="customAmount">Custom Amount (INR)</label>
                  <input type="number" id="customAmount" placeholder="Enter custom amount..." min="100" class="form-input" />
                </div>
              </div>

              <!-- Step 2: Allocation -->
              <div class="step-container">
                <h3 class="step-title"><span class="step-badge">2</span> Allocate Funding Pool</h3>
                <div class="form-group">
                  <label for="causeAllocation">Target Project</label>
                  <select id="causeAllocation" required class="form-input">
                    <option value="general">General Operations Fund</option>
                    <option value="bachpanshala">Project BachpanSala (Education)</option>
                    <option value="udaan">Project Udaan (Women Empowerment)</option>
                    <option value="jeev">Project Jeev (Animal Welfare)</option>
                    <option value="seva">Project Seva (Social Relief)</option>
                    <option value="prakriti">Project Prakriti (Environment)</option>
                    <option value="vikas">Project Vikas (Youth Careers)</option>
                  </select>
                </div>
              </div>

              <!-- Step 3: Details -->
              <div class="step-container">
                <h3 class="step-title"><span class="step-badge">3</span> Donor Credentials</h3>
                <div class="form-row">
                  <div class="form-group">
                    <label for="donorName">Full Name</label>
                    <input type="text" id="donorName" required placeholder="e.g., Adithya Kumar" class="form-input" />
                  </div>
                  <div class="form-group">
                    <label for="donorEmail">Email Address</label>
                    <input type="email" id="donorEmail" required placeholder="e.g., support@domain.com" class="form-input" />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="donorPan">PAN Card Number (For 80G Receipt)</label>
                    <input type="text" id="donorPan" placeholder="e.g., ABCDE1234F" pattern="[A-Z]{5}[0-9]{4}[A-Z]{1}" title="Please enter a valid 10-character PAN number" class="form-input uppercase" />
                  </div>
                  <div class="form-group">
                    <label for="donorPhone">Phone Number</label>
                    <input type="tel" id="donorPhone" required placeholder="e.g., +91 98765 43210" class="form-input" />
                  </div>
                </div>
              </div>

              <!-- Step 4: Payment via Razorpay -->
              <div class="step-container">
                <h3 class="step-title"><span class="step-badge">4</span> Secure Payment</h3>
                <div class="razorpay-info">
                  <div class="razorpay-badge">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    <span>Secured by Razorpay</span>
                  </div>
                  <p class="razorpay-desc">
                    Your payment will be processed securely through Razorpay's PCI-DSS compliant gateway. All major cards, UPI, net banking, and wallets are accepted.
                  </p>
                  <div class="payment-methods">
                    <div class="method-pill">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                      <span>Cards</span>
                    </div>
                    <div class="method-pill">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                      <span>UPI</span>
                    </div>
                    <div class="method-pill">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                      <span>Netbanking</span>
                    </div>
                    <div class="method-pill">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 000 4h4v-4h-4z"/></svg>
                      <span>Wallets</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right Side: Sticky Checkout Summary -->
            <div class="checkout-summary">
              <div class="summary-card">
                <h4 class="summary-title">Summary</h4>
                <div class="summary-row">
                  <span>Selected Cause</span>
                  <span id="summaryCause" class="summary-highlight">General Fund</span>
                </div>
                <div class="summary-row">
                  <span>Donation Frequency</span>
                  <span class="summary-highlight">One-Time Contribution</span>
                </div>
                <div class="summary-row">
                  <span>80G Tax Exemption</span>
                  <span class="summary-highlight text-green">Eligible (50% Deduction)</span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-row total-row">
                  <span>Total Contribution</span>
                  <span id="summaryTotal">₹1,000</span>
                </div>
                
                <button type="submit" class="btn-checkout" id="payBtn">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  Pay with Razorpay
                </button>
                <p class="checkout-disclaimer">By clicking, you agree to our terms of compliance and Section 8 donation guidelines. Payment is processed securely by Razorpay.</p>
              </div>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<!-- Razorpay Checkout SDK -->
<script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  // State variables
  let currentAmount = 1000;

  // Amount preset buttons
  const presetBtns = document.querySelectorAll('.preset-btn');
  const customAmountInput = document.getElementById('customAmount') as HTMLInputElement;
  const summaryTotal = document.getElementById('summaryTotal');
  const summaryCauseText = document.getElementById('summaryCause');
  const causeSelect = document.getElementById('causeAllocation') as HTMLSelectElement;

  // Format helper
  const formatINR = (val) => {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      maximumFractionDigits: 0
    }).format(val);
  };

  const updateAmount = (amount) => {
    currentAmount = amount;
    if (summaryTotal) summaryTotal.textContent = formatINR(currentAmount);
  };

  // Listeners for presets
  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      presetBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (customAmountInput) customAmountInput.value = '';
      
      const val = parseInt(btn.getAttribute('data-value') || '1000');
      updateAmount(val);
    });
  });

  // Custom amount listener
  if (customAmountInput) {
    customAmountInput.addEventListener('input', () => {
      presetBtns.forEach(b => b.classList.remove('active'));
      const val = parseInt(customAmountInput.value);
      if (val && val >= 100) {
        updateAmount(val);
      } else {
        updateAmount(0);
      }
    });
  }

  // Sync cause selection with summary
  if (causeSelect && summaryCauseText) {
    const updateSummaryCause = () => {
      const text = causeSelect.options[causeSelect.selectedIndex].text.replace(/Project | \(.*\)/g, '');
      summaryCauseText.textContent = text;
    };
    causeSelect.addEventListener('change', updateSummaryCause);
    
    // Read query parameter and auto-select
    const params = new URLSearchParams(window.location.search);
    const causeParam = params.get('cause');
    if (causeParam) {
      const option = causeSelect.querySelector(`option[value="${causeParam}"]`) as HTMLOptionElement;
      if (option) {
        option.selected = true;
        updateSummaryCause();
      }
    }
  }

  // Razorpay Checkout integration
  const form = document.getElementById('donationForm') as HTMLFormElement;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const donorName = (document.getElementById('donorName') as HTMLInputElement).value;
      const donorEmail = (document.getElementById('donorEmail') as HTMLInputElement).value;
      const donorPhone = (document.getElementById('donorPhone') as HTMLInputElement).value;
      const allocationText = causeSelect ? causeSelect.options[causeSelect.selectedIndex].text : 'General Fund';

      if (!donorName || !donorEmail || !donorPhone) {
        alert('Please fill in all required fields.');
        return;
      }

      if (currentAmount < 100) {
        alert('Minimum donation amount is ₹100.');
        return;
      }

      // Direct redirect to hosted Razorpay payment link in same window (no new tab)
      const params = new URLSearchParams();
      if (currentAmount) {
        params.append('amount', currentAmount.toString());
      }
      if (donorName) {
        params.append('name', donorName);
        params.append('prefill[name]', donorName);
      }
      if (donorEmail) {
        params.append('email', donorEmail);
        params.append('prefill[email]', donorEmail);
      }
      if (donorPhone) {
        params.append('contact', donorPhone);
        params.append('prefill[contact]', donorPhone);
      }
      
      const redirectUrl = `https://rzp.io/l/kWQ87HP?${params.toString()}`;
      window.location.href = redirectUrl;
    });
  }

  function showSuccessMessage(name: string, amount: number, cause: string) {
    // Create success overlay dynamically
    const overlay = document.createElement('div');
    overlay.className = 'success-overlay active';
    overlay.innerHTML = `
      <div class="success-card">
        <span class="success-icon">✓</span>
        <h2>Contribution Completed!</h2>
        <p class="success-lead">Thank you, <strong>${name}</strong>, for your generous support.</p>
        
        <div class="receipt-box">
          <div class="receipt-row">
            <span>Amount Transacted:</span>
            <strong>${formatINR(amount)}</strong>
          </div>
          <div class="receipt-row">
            <span>Fund Allocation:</span>
            <strong>${cause}</strong>
          </div>
          <div class="receipt-row">
            <span>Transaction Status:</span>
            <strong class="text-green">SUCCESS</strong>
          </div>
        </div>

        <p class="success-footer-text">
          A formal tax-exempt 80G receipt and transaction statement will be dispatched to your email.
        </p>
        <a href="/" class="btn-primary-pill">Back to Home</a>
      </div>
    `;
    
    document.body.appendChild(overlay);
    document.body.classList.add('no-scroll');
  }
</script>

<style>
  .donate-page {
    background-color: var(--color-canvas);
    padding-bottom: 96px;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-hero {
    padding: 160px 0 64px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .eyebrow.center {
    justify-content: center;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 24px;
  }

  .page-subtitle {
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 450;
    line-height: 1.5;
    color: var(--color-slate);
    max-width: 800px;
  }

  /* Checkout layouts */
  .checkout-section {
    padding-bottom: 96px;
  }

  .checkout-wrapper {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
    overflow: hidden;
  }

  .checkout-form {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: flex-start;
  }

  .checkout-inputs {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .step-container {
    background-color: var(--color-lifted);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 40px;
    padding: 48px;
    box-shadow: rgba(0, 0, 0, 0.01) 0px 4px 16px;
  }

  .step-title {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }

  .step-badge {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--color-ink);
    color: var(--color-canvas);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* Step 1: Amounts presets */
  .amount-presets {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .preset-btn {
    background-color: var(--color-white);
    border: 1px solid var(--color-dust);
    color: var(--color-ink);
    padding: 14px 0;
    border-radius: 20px;
    font-family: var(--font-secondary);
    font-size: 1.1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .preset-btn:hover {
    border-color: var(--color-ink);
  }

  .preset-btn.active {
    background-color: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-canvas);
  }

  .custom-amount-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Form Elements */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
  }

  .form-input {
    background-color: var(--color-white);
    border: 1px solid var(--color-dust);
    border-radius: 20px;
    padding: 12px 20px;
    font-family: var(--font-secondary);
    font-size: 0.95rem;
    color: var(--color-ink);
    outline: none;
    transition: all 0.25s ease;
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: rgba(1, 191, 123, 0.08) 0px 0px 0px 4px;
  }

  .form-input.uppercase {
    text-transform: uppercase;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 20px;
  }

  /* Step 4: Razorpay info */
  .razorpay-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .razorpay-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, rgba(1, 191, 123, 0.08), rgba(1, 191, 123, 0.02));
    border: 1px solid rgba(1, 191, 123, 0.15);
    border-radius: 16px;
    padding: 10px 20px;
    color: var(--color-accent);
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    font-weight: 600;
    width: fit-content;
  }

  .razorpay-desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-slate);
  }

  .payment-methods {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .method-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: var(--color-white);
    border: 1px solid var(--color-dust);
    border-radius: 14px;
    padding: 8px 16px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-slate);
    font-family: var(--font-secondary);
  }

  /* Sticky Summary Card on right */
  .checkout-summary {
    position: sticky;
    top: 120px;
  }

  .summary-card {
    background-color: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 40px;
    padding: 48px;
    box-shadow: rgba(0, 0, 0, 0.03) 0px 16px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .summary-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .summary-highlight {
    font-weight: 500;
    color: var(--color-ink);
  }

  .text-green {
    color: var(--color-accent) !important;
    font-weight: 700;
  }

  .summary-divider {
    height: 1px;
    background-color: var(--color-dust);
    margin: 8px 0;
  }

  .total-row {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .total-row span:nth-child(2) {
    font-family: var(--font-primary);
    font-size: 1.75rem;
    color: var(--color-accent);
  }

  .btn-checkout {
    background-color: var(--color-ink);
    color: var(--color-canvas);
    font-family: var(--font-secondary);
    font-size: 1rem;
    font-weight: 500;
    padding: 14px 0;
    border-radius: 20px;
    border: 1.5px solid var(--color-ink);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
    width: 100%;
    margin-top: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-checkout:hover {
    background-color: transparent;
    color: var(--color-ink);
  }

  .checkout-disclaimer {
    font-size: 0.75rem;
    color: rgba(20, 20, 19, 0.4);
    line-height: 1.4;
    text-align: center;
    margin-top: 8px;
  }

  /* Success overlay */
  .success-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.99);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 48px;
    z-index: 9999;
  }

  .success-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .success-card {
    text-align: center;
    max-width: 540px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: rgba(1, 191, 123, 0.1);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.25rem;
    font-weight: 700;
  }

  .success-card h2 {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  .success-lead {
    font-size: 1.1rem;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .receipt-box {
    background-color: var(--color-canvas);
    border-radius: 24px;
    padding: 24px 32px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: left;
    box-shadow: inset rgba(0, 0, 0, 0.02) 0px 2px 8px;
    border: 1px solid var(--color-dust);
  }

  .receipt-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .receipt-row strong {
    color: var(--color-ink);
  }

  .success-footer-text {
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--color-slate);
    margin-bottom: 8px;
  }

  .btn-primary-pill {
    display: inline-block;
    background-color: var(--color-ink);
    color: var(--color-canvas);
    font-family: var(--font-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 12px 32px;
    border-radius: 20px;
    border: 1.5px solid var(--color-ink);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
    text-decoration: none;
  }

  .btn-primary-pill:hover {
    background-color: transparent;
    color: var(--color-ink);
  }

  /* Responsive styles */
  @media (max-width: 991px) {
    .checkout-form {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .checkout-summary {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .step-container, .summary-card {
      padding: 32px 24px;
      border-radius: 24px;
    }

    .amount-presets {
