---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const impactMetrics = [
  { value: "50,000+", label: "BENEFICIARIES REACHED", desc: "Families fed, kids educated, and street animals rescued across communities." },
  { value: "28", label: "STATES ENGAGED", desc: "A unified presence spanning regional rural sectors and urban slums in India." },
  { value: "200+", label: "VOLUNTEERS DEPLOYED", desc: "Interns and professionals driving daily feeding runs and classroom lessons." },
  { value: "6", label: "ACTIVE CAMPAIGNS", desc: "Coordinated initiatives targeting education, animal welfare, and environment." }
];

const allocations = [
  { project: "Project BachpanSala (Child Education)", pct: 40, color: "#01BF7B", details: "Textbooks, mid-day meals, learning kits, and teacher allowances." },
  { project: "Project Seva (Slum Feeding & Relief)", pct: 30, color: "#00CC83", details: "Cooking ingredients, clothing drives, and winter blanket distributions." },
  { project: "Project Jeev (Animal Welfare & Veterinary)", pct: 15, color: "#141413", details: "Medical support, stray feeding runs, and shelter repairs." },
  { project: "Project Prakriti & Vikas (Green & Skills)", pct: 15, color: "#696969", details: "Tree saplings, cleanups, computer training kits, and youth seminars." }
];
---

<Layout>
  <Navbar />
  
  <main class="impact-page">
    <!-- Hero Header -->
    <section class="page-hero">
      <div class="container text-center">
        <div class="eyebrow center">
          <span class="eyebrow-dot"></span>
          <span>ON-GROUND SUCCESS METRICS</span>
        </div>
        <h1 class="page-title">Our Social Impact</h1>
        <p class="page-subtitle">
          We turn donor funding into measurable social benefits. Explore our tracking indices, program allocations, and supervisor dispatches.
        </p>
      </div>
    </section>

    <!-- Metrics Cards Grid -->
    <section class="metrics-section">
      <div class="container">
        <div class="metrics-grid">
          {impactMetrics.map(metric => (
            <div class="metric-card" key={metric.label}>
              <div class="metric-value">{metric.value}</div>
              <h3 class="metric-label">
                <span class="label-dot"></span>
                {metric.label}
              </h3>
              <p class="metric-desc">{metric.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Funding Allocation Progress Bars -->
    <section class="allocations-section">
      <div class="container">
        <div class="allocations-box">
          <div class="allocations-header">
            <h2 class="section-title">Where Your Contributions Go</h2>
            <p class="section-subtitle">Transparency is core to InAmigos. Here is how public contributions are distributed across program costs.</p>
          </div>

          <div class="allocations-list">
            {allocations.map(alloc => (
              <div class="alloc-item" key={alloc.project}>
                <div class="alloc-details">
                  <span class="alloc-name">{alloc.project}</span>
                  <span class="alloc-pct">{alloc.pct}%</span>
                </div>
                <div class="alloc-track">
                  <div class="alloc-fill" style={`width: ${alloc.pct}%; background-color: ${alloc.color};`}></div>
                </div>
                <p class="alloc-description">{alloc.details}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Volunteer Stories / Field Notes -->
    <section class="stories-section">
      <div class="container">
        <div class="stories-header">
          <div class="eyebrow">
            <span class="eyebrow-dot"></span>
            <span>FIELD DISPATCHES</span>
          </div>
          <h2 class="section-title">Testimonials From Our Team</h2>
        </div>

        <div class="stories-grid">
          <!-- Story 1 -->
          <div class="story-card">
            <p class="story-text">
              "Coordinating Project Seva feeding runs in Uttar Pradesh taught me that change begins with simple acts of service. Seeing the joy of children when they receive fresh meals is incredibly rewarding."
            </p>
            <div class="story-author">
              <strong>Faiz Khan</strong>
              <span>Volunteer Supervisor, Uttar Pradesh</span>
            </div>
          </div>

          <!-- Story 2 -->
          <div class="story-card">
            <p class="story-text">
              "Under Project BachpanSala, we run tutoring sessions for children in slum blocks. Witnessing their interest in learning and basic mathematics double within months confirms our approach is working."
            </p>
            <div class="story-author">
              <strong>Manavi Jaiswal</strong>
              <span>Junior Associate, Chhattisgarh</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .impact-page {
    background-color: var(--color-canvas);
    padding-bottom: 96px;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-hero {
    padding: 160px 0 64px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .eyebrow.center {
    justify-content: center;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 24px;
  }

  .page-subtitle {
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 450;
    line-height: 1.5;
    color: var(--color-slate);
    max-width: 800px;
  }

  /* Metrics Grid */
  .metrics-section {
    padding-bottom: 96px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .metric-card {
    background-color: var(--color-lifted);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 40px; /* Stadium card corners */
    padding: 40px 32px;
    box-shadow: rgba(0, 0, 0, 0.01) 0px 4px 16px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .metric-card:hover {
    transform: translateY(-6px);
    border-color: rgba(1, 191, 123, 0.2);
  }

  .metric-value {
    font-family: var(--font-primary);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    line-height: 1;
    margin-bottom: 16px;
  }

  .metric-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-secondary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-ink);
    margin-bottom: 12px;
  }

  .label-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .metric-desc {
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--color-slate);
    font-weight: 450;
  }

  /* Allocations Section styling */
  .allocations-section {
    padding-bottom: 96px;
  }

  .allocations-box {
    background-color: var(--color-lifted);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 40px;
    padding: 56px;
    box-shadow: rgba(0, 0, 0, 0.02) 0px 8px 32px;
  }

  .allocations-header {
    margin-bottom: 48px;
    max-width: 600px;
  }

  .section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.25rem);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-slate);
  }

  .allocations-list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .alloc-item {
    display: flex;
    flex-direction: column;
  }

  .alloc-details {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 8px;
  }

  .alloc-track {
    height: 8px;
    background-color: var(--color-canvas);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .alloc-fill {
    height: 100%;
    border-radius: 4px;
  }

  .alloc-description {
    font-size: 0.85rem;
    color: var(--color-slate);
    line-height: 1.4;
  }

  /* Stories Section */
  .stories-section {
    padding: 96px 0;
    border-top: 1px solid var(--color-dust);
  }

  .stories-header {
    margin-bottom: 56px;
  }

  .stories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .story-card {
    background-color: var(--color-lifted);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 40px;
    padding: 48px;
    box-shadow: rgba(0, 0, 0, 0.01) 0px 4px 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 260px;
  }

  .story-text {
    font-size: 1.05rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-slate);
    margin-bottom: 32px;
  }

  .story-author {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .story-author strong {
    font-size: 1rem;
    color: var(--color-ink);
    font-weight: 600;
  }

  .story-author span {
    font-size: 0.82rem;
    color: var(--color-accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Responsive styling */
  @media (max-width: 991px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .stories-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 576px) {
    .metrics-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .metric-card, .allocations-box, .story-card {
      padding: 32px 24px;
      border-radius: 24px;
    }
  }
</style>
