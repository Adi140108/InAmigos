---

<Layout>
  <Navbar />
  
  <main class="team-page">
    <!-- Hero Header -->
    <section class="page-hero">
      <div class="container text-center">
        <div class="eyebrow center">
          <span class="eyebrow-dot"></span>
          <span>OUR CONSTELATION</span>
        </div>
        <h1 class="page-title">Meet Our Dedicated Team</h1>
        <p class="page-subtitle">
          Driven professionals, supervisors, and community advocates directing daily operations to ensure our campaigns succeed.
        </p>
      </div>
    </section>

    <!-- Team Grid -->
    <section class="team-section">
      <div class="container">
        <div class="team-grid" id="teamGrid">
          {leadership.map((member, idx) => (
            <div class={`team-card card-${idx + 1}`} key={member.name}>
              <div class="portrait-wrapper">
                <img src={member.img} alt={member.name} class="portrait-image" loading="lazy" />
                <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="satellite-cta" aria-label={`LinkedIn profile for ${member.name}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" class="arrow-icon"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
              </div>
              <div class="member-info">
                <div class="member-eyebrow">
                  <span class="accent-dot"></span>
                  <span>{member.tag}</span>
                </div>
                <h3 class="member-name">{member.name}</h3>
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class={`member-email ${!member.email ? 'hidden' : ''}`}>{member.email}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .team-page {
    background-color: var(--color-canvas);
    padding-bottom: 96px;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-hero {
    padding: 160px 0 64px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .eyebrow.center {
    justify-content: center;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 24px;
  }

  .page-subtitle {
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 450;
    line-height: 1.5;
    color: var(--color-slate);
    max-width: 800px;
  }

  /* Grid Layout */
  .team-section {
    padding-bottom: 64px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    opacity: 1;
    transform: scale(1);
  }

  .team-card.hidden {
    display: none;
  }

  .member-email.hidden {
    display: none;
  }

  .team-card:hover {
    transform: translateY(-8px);
  }

  /* Perfect circular portrait image mask matching DESIGN.md */
  .portrait-wrapper {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    position: relative;
    margin-bottom: 24px;
    box-shadow: rgba(0, 0, 0, 0.06) 0px 8px 24px;
    background-color: var(--color-white);
  }

  .portrait-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
    border: 4px solid var(--color-white);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-card:hover .portrait-image {
    transform: scale(1.05);
  }

  /* Satellite CTA button */
  .satellite-cta {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 5;
  }

  .arrow-icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
    color: var(--color-ink);
    transition: color 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .satellite-cta:hover {
    background-color: var(--color-ink);
    transform: scale(1.08);
  }

  .satellite-cta:hover .arrow-icon {
    color: var(--color-canvas);
  }

  /* Info */
  .member-info {
    padding: 0 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .member-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-secondary);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    margin-bottom: 8px;
  }

  .accent-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .member-name {
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-bottom: 6px;
  }

  .member-role {
    font-size: 0.85rem;
    font-weight: 450;
    color: var(--color-slate);
    margin-bottom: 8px;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .member-email {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
    word-break: break-all;
  }

  .member-email:hover {
    color: var(--color-ink);
    text-decoration: underline;
  }

  /* Responsive styling */
  @media (max-width: 1200px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 991px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 24px;
    }
  }

  @media (max-width: 576px) {
    .team-grid {
      grid-template-columns: 1fr;
      gap: 36px 0;
    }
    
    .portrait-wrapper {
      width: 160px;
      height: 160px;
    }
  }
</style>
