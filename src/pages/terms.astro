---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <main class="legal-page">
    <section class="page-hero">
      <div class="container">
        <div class="eyebrow">
          <span class="eyebrow-dot"></span>
          <span>LEGAL COMPLIANCE</span>
        </div>
        <h1 class="page-title">Terms & Conditions</h1>
        <p class="page-subtitle">Last updated: June 20, 2026</p>
      </div>
    </section>

    <section class="legal-content">
      <div class="container">
        <div class="legal-box">
          <h2>1. Terms Acceptance</h2>
          <p>By browsing this awareness page and submitting applications (Volunteer or Donation checkout), you agree to comply with our code of ethics, community safety policies, and Section 8 legal compliance guidelines.</p>

          <h2>2. Volunteer Obligations</h2>
          <p>Volunteers register to support projects voluntarily without administrative compensation unless formally stated. All code, designs, or resources built during volunteer associate internships remain property of InAmigos Foundation.</p>

          <h2>3. Mock Donation Terms</h2>
          <p>This website runs as a fully mock demonstration checkout portal. No real money is captured or transacted under these forms. Real donations should be directed solely through our official verified Razorpay accounts.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page {
    background-color: var(--color-canvas);
    padding-bottom: 96px;
  }
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .page-hero {
    padding: 160px 0 48px;
  }
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }
  .page-title {
    font-size: 3rem;
    font-weight: 500;
    color: var(--color-ink);
  }
  .page-subtitle {
    font-size: 1rem;
    color: var(--color-slate);
    margin-top: 12px;
  }
  .legal-content {
    padding-bottom: 64px;
  }
  .legal-box {
    background-color: var(--color-lifted);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 40px;
    padding: 48px;
    box-shadow: rgba(0, 0, 0, 0.01) 0px 4px 16px;
  }
  .legal-box h2 {
    font-size: 1.35rem;
    font-weight: 500;
    margin: 32px 0 16px;
    color: var(--color-ink);
  }
  .legal-box h2:first-child {
    margin-top: 0;
  }
  .legal-box p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-slate);
  }
  @media (max-width: 576px) {
    .legal-box {
      padding: 32px 24px;
      border-radius: 24px;
    }
  }
</style>
