---
// Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer-area">
  <div class="footer-container">
    <!-- Large Conversational Headline -->
    <div class="footer-header">
      <h2 class="footer-headline">Let's build a more inclusive, compassionate society together.</h2>
    </div>

    <!-- 4-Column Link Grid -->
    <div class="footer-grid">
      <!-- Col 1: Core Campaigns -->
      <div class="footer-column">
        <h4 class="column-header">OUR CAUSES</h4>
        <ul class="column-links">
          <li><a href="#projects" class="footer-link">Project BachpanSala</a></li>
          <li><a href="#projects" class="footer-link">Project Udaan</a></li>
          <li><a href="#projects" class="footer-link">Project Jeev</a></li>
          <li><a href="#projects" class="footer-link">Project Seva</a></li>
          <li><a href="#projects" class="footer-link">Project Prakriti</a></li>
          <li><a href="#projects" class="footer-link">Project Vikas</a></li>
        </ul>
      </div>

      <!-- Col 2: Action links -->
      <div class="footer-column">
        <h4 class="column-header">GET INVOLVED</h4>
        <ul class="column-links">
          <li><a href="/volunteer" class="footer-link">Become a Volunteer</a></li>
          <li><a href="/donate" class="footer-link">Donate Now</a></li>
          <li><a href="/volunteer#roster" class="footer-link">Volunteer Roster</a></li>
          <li><a href="/about#csr" class="footer-link">Corporate CSR Avenues</a></li>
        </ul>
      </div>

      <!-- Col 3: NGO Profile -->
      <div class="footer-column">
        <h4 class="column-header">ABOUT NGO</h4>
        <ul class="column-links">
          <li><a href="/about" class="footer-link">Our Foundational Story</a></li>
          <li><a href="/work" class="footer-link">Our Methodology</a></li>
          <li><a href="/team" class="footer-link">Meet Our Team</a></li>
          <li><a href="/about#benefits" class="footer-link">Tax Benefits (80G/12A)</a></li>
          <li><a href="/gallery" class="footer-link">Media Gallery</a></li>
          <li><a href="/blog" class="footer-link">Official Blog</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact details -->
      <div class="footer-column">
        <h4 class="column-header">GET IN TOUCH</h4>
        <ul class="column-links contact-info">
          <li class="contact-item">
            <span class="contact-icon">✉</span>
            <a href="mailto:support@inamigosfoundation.org.in" class="footer-link">support@inamigosfoundation.org.in</a>
          </li>
          <li class="contact-item">
            <span class="contact-icon">📍</span>
            <span class="contact-text">Chhattisgarh Base, Operating Pan-India</span>
          </li>
          <li class="contact-item">
            <span class="contact-icon">📄</span>
            <span class="contact-text">NITI Aayog Registered (#CG/2020/0268598)</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider Line -->
    <div class="footer-divider"></div>

    <!-- Bottom Row: Copyright & Utilities -->
    <div class="footer-bottom">
      <div class="bottom-left">
        <p class="copyright">© {currentYear} InAmigos Foundation. Section 8 Non-Profit. All Rights Reserved.</p>
        <div class="bottom-legal-links">
          <a href="/privacy" class="bottom-link">Privacy Policy</a>
          <a href="/terms" class="bottom-link">Terms & Conditions</a>
        </div>
      </div>

      <div class="bottom-right">
        <!-- Country Selector Pill -->
        <div class="country-selector">
          <span class="flag-icon">🇮🇳</span>
          <span>India (English)</span>
          <span class="chevron-down">▼</span>
        </div>

        <!-- Social Icons -->
        <div class="social-icons">
          <a href="https://www.facebook.com/inamigos.inamigos" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a href="https://www.instagram.com/inamigos/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.4-1.439-1.4z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/inamigos-foundation/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-area {
    background-color: var(--color-ink); /* Near Black */
    color: var(--color-white);
    padding: 96px 0 128px;
    position: relative;
    z-index: 10;
  }

  .footer-container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .footer-header {
    margin-bottom: 64px;
    max-width: 800px;
  }

  .footer-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
    margin-bottom: 80px;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .column-header {
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .column-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    font-weight: 450;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-accent-light);
  }

  .footer-link.external {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .ext-arrow {
    font-size: 0.75rem;
    opacity: 0.6;
    transition: transform 0.2s ease;
  }

  .footer-link.external:hover .ext-arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  .contact-info {
    gap: 16px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 450;
    line-height: 1.4;
  }

  .contact-icon {
    font-size: 1rem;
    opacity: 0.7;
  }

  .footer-divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.1);
    margin-bottom: 40px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 28px;
  }

  .bottom-left {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .copyright {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 450;
  }

  .bottom-legal-links {
    display: flex;
    gap: 20px;
  }

  .bottom-link {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s ease;
  }

  .bottom-link:hover {
    color: var(--color-white);
  }

  .bottom-right {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  /* Country selector pill matching DESIGN.md */
  .country-selector {
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-white);
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .country-selector:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .flag-icon {
    font-size: 0.95rem;
  }

  .chevron-down {
    font-size: 0.6rem;
    opacity: 0.6;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .social-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    color: var(--color-white);
    transition: transform 0.2s ease;
  }

  .social-btn:hover svg {
    transform: scale(1.1);
  }

  .social-btn:hover {
    background-color: var(--color-accent);
    transform: translateY(-2px);
  }

  /* Responsive styles */
  @media (max-width: 991px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 36px;
    }
  }

  @media (max-width: 576px) {
    .footer-area {
      padding: 64px 0 48px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .bottom-right {
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .social-icons {
      width: 100%;
    }
  }
</style>
